{
 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# 🧪 Nanoparticle Size Distribution – Interactive Notebook\n",
    "\n",
    "This notebook lets you process SEM/TEM images using the modular pipeline, step by step.\n",
    "\n",
    "- Detect scale bar\n",
    "- Preprocess the image\n",
    "- Segment particles\n",
    "- Measure diameters\n",
    "- Plot histogram and export data"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# 📦 Imports\n",
    "import os\n",
    "from utils.scale_bar import detect_scale_bar_length\n",
    "from scripts.preprocessing.clahe_filter import preprocess_image\n",
    "from scripts.segmentation.otsu_segment import segment_particles\n",
    "from scripts.analysis.size_measurement import measure_particles, export_to_latex\n",
    "from scripts.visualization.plotting import plot_results\n",
    "import matplotlib.pyplot as plt\n",
    "from skimage.color import label2rgb"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# 🔧 Set Parameters\n",
    "image_path = "../data/raw/SEM_nano_particles.png"\n",
    "scale_bar_length_nm = 100  # known real length in nanometers"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# 🧮 Detect scale bar and calibrate\n",
    "scale_bar_px = detect_scale_bar_length(image_path)\n",
    "nm_per_pixel = scale_bar_length_nm / scale_bar_px\n",
    "print(f"Scale bar: {scale_bar_px} px → {nm_per_pixel:.2f} nm/pixel")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# 🧽 Preprocess\n",
    "binary_mask, original = preprocess_image(image_path)\n",
    "plt.imshow(binary_mask, cmap='gray')\n",
    "plt.title("Binary Mask after CLAHE + Otsu")\n",
    "plt.axis('off')\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# 🧱 Segment particles\n",
    "labeled_image, regions = segment_particles(binary_mask)\n",
    "overlay = label2rgb(labeled_image, image=original, bg_label=0)\n",
    "plt.imshow(overlay)\n",
    "plt.title("Labeled Particles")\n",
    "plt.axis('off')\n",
    "plt.show()\n",
    "print(f"Total regions: {len(regions)}")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# 📏 Measure and export\n",
    "diameters = measure_particles(regions, labeled_image, original, nm_per_pixel)\n",
    "export_to_latex(diameters, image_path)\n",
    "print(f"Measured {len(diameters)} particles")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# 📊 Plot histogram\n",
    "plot_results(diameters, image_path)"
   ]
  }
 ],
